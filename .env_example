# =========================
# 1) Minimal start (required)
# =========================
WG_HOST=
# Example: WG_HOST=vpn.example.com
# Auto public IP detection: WG_HOST=auto

# =========================
# 2) Minimal start (recommended)
# =========================
# PASSWORD_HASH=
# PASSWORD=
# LANG=ru
# PORT=51821
# WEBUI_HOST=0.0.0.0
# WG_PORT=51820
# WG_DEVICE=eth0

# =========================
# 3) WireGuard defaults (optional)
# =========================
# WG_CONFIG_PORT=51820
# WG_MTU=
# WG_PERSISTENT_KEEPALIVE=0
# WG_DEFAULT_ADDRESS=10.8.0.x
# WG_DEFAULT_DNS=1.1.1.1
# WG_ALLOWED_IPS=0.0.0.0/0, ::/0

# Hooks
# WG_PRE_UP=
# WG_POST_UP=
# WG_PRE_DOWN=
# WG_POST_DOWN=

# =========================
# 4) UI features (optional)
# =========================
# WG_ENABLE_EXPIRES_TIME=false
# WG_ENABLE_ONE_TIME_LINKS=false
# UI_TRAFFIC_STATS=false
# UI_CHART_TYPE=0
# UI_ENABLE_SORT_CLIENTS=false
# MAX_AGE=0
# DICEBEAR_TYPE=bottts
# USE_GRAVATAR=true

# =========================
# 5) HTTPS profile (optional)
# Enable if you have mounted cert/key inside container
# =========================
# SSL_ENABLED=true
# SSL_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

# =========================
# 6) Prometheus/Zabbix profile (optional)
# =========================
# ENABLE_PROMETHEUS_METRICS=false
# PROMETHEUS_METRICS_PASSWORD=
# PROMETHEUS_METRICS_PASSWORD_HASH=

# =========================
# 7) AmneziaWG obfuscation profile (optional)
# =========================
# JC=
# JMIN=50
# JMAX=1000
# S1=
# S2=
# H1=
# H2=
# H3=
# H4=
