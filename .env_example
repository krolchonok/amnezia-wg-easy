# =========================
# 1) Bootstrap only (required)
# =========================
PORT=51821
WEBUI_HOST=0.0.0.0
WG_PATH=/etc/wireguard/
WG_DEVICE=eth0

# =========================
# 2) Bootstrap only (optional)
# =========================
# LANG=ru
# MAX_AGE=0

# =========================
# 3) HTTPS bootstrap (optional)
# These must exist before the web server starts
# =========================
# SSL_ENABLED=true
# SSL_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

# =========================
# 4) WireGuard hooks / host networking (optional)
# These are system/bootstrap-level and should stay in env
# =========================
# WG_PRE_UP=
# WG_POST_UP=
# WG_PRE_DOWN=
# WG_POST_DOWN=
# WG_UPLINK_CONFIGS_PATH=/etc/wireguard/uplinks

# =========================
# 5) Prometheus/Zabbix profile (optional)
# Still env-based
# =========================
# ENABLE_PROMETHEUS_METRICS=false
# PROMETHEUS_METRICS_PASSWORD=
# PROMETHEUS_METRICS_PASSWORD_HASH=

# =========================
# 6) AmneziaWG obfuscation profile (optional)
# Still env-based bootstrap defaults
# =========================
# JC=
# JMIN=50
# JMAX=1000
# S1=
# S2=
# H1=
# H2=
# H3=
# H4=

# =========================
# Everything else is configured in web setup/settings:
# - admin password
# - WG_HOST
# - client DNS
# - WG_PORT / WG_CONFIG_PORT / WG_MTU
# - WG_DEFAULT_ADDRESS / WG_ALLOWED_IPS / keepalive
# - UI flags / avatars / one-time links / expires
# - Telegram bot
# - traffic history
# - uplinks / DNS routing / ACL / categories
# =========================
