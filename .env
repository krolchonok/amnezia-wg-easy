WG_HOST=馃毃YOUR_SERVER_IP
# (Supports: en, ru, tr, no, pl, fr, de, ca, es)
LANGUAGE=ru
PORT=51821
WG_DEVICE=eth0
WG_PORT=51820
WG_DEFAULT_ADDRESS=10.8.0.x
WG_DEFAULT_DNS=1.1.1.1
WG_ALLOWED_IPS=0.0.0.0/0, ::/0
DICEBEAR_TYPE=bottts
USE_GRAVATAR=true
SSL_ENABLED=true
